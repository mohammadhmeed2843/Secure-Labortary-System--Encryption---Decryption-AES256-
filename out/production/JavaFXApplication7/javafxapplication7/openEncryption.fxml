<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import java.net.URL?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/21"
            fx:controller="javafxapplication7.openEncryptionController"
            prefWidth="760" prefHeight="530"
            styleClass="screen-root">

    <stylesheets><URL value="@styles.css"/></stylesheets>

    <!-- ── TOP BAR ── -->
    <top>
        <HBox styleClass="top-bar" alignment="CENTER_LEFT" spacing="16">
            <Button text="&#8592; Back" onAction="#backToHomePage" styleClass="btn-ghost"/>
            <Separator orientation="VERTICAL"
                       style="-fx-background-color:#252d3d; -fx-pref-height:28;"/>
            <VBox spacing="2">
                <Label text="Encrypt PDF File" styleClass="page-title"/>
                <Label text="AES-256 CBC encryption for medical documents" styleClass="page-subtitle"/>
            </VBox>
        </HBox>
    </top>

    <!-- ── CENTER ── -->
    <center>
        <VBox spacing="14" style="-fx-padding: 20 24;">

            <!-- Step indicators -->
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label text="&#9312; Select File"
                       style="-fx-text-fill:#3b82f6; -fx-font-weight:bold; -fx-font-size:12px;"/>
                <Label text="&#8250;" style="-fx-text-fill:#252d3d; -fx-font-size:14px;"/>
                <Label text="&#9313; Enter Keys"
                       style="-fx-text-fill:#5a6480; -fx-font-size:12px;"/>
                <Label text="&#8250;" style="-fx-text-fill:#252d3d; -fx-font-size:14px;"/>
                <Label text="&#9314; Output &amp; Encrypt"
                       style="-fx-text-fill:#5a6480; -fx-font-size:12px;"/>
            </HBox>

            <!-- 1 — File Selection -->
            <VBox styleClass="card" spacing="10">
                <Label text="PDF FILE" styleClass="section-label"/>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <TextField fx:id="inputFolderTextField"
                               promptText="No file selected — click Browse"
                               styleClass="form-field" HBox.hgrow="ALWAYS"
                               editable="false"/>
                    <Button text="Browse Files" onAction="#browseInputFolder"
                            prefWidth="130" prefHeight="36" styleClass="btn-primary"/>
                </HBox>
            </VBox>

            <!-- 2 — Keys -->
            <VBox styleClass="card" spacing="12">
                <Label text="ENCRYPTION KEYS" styleClass="section-label"/>

                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="Key" styleClass="field-label" prefWidth="40"
                           style="-fx-text-fill:#8892aa; -fx-font-size:12px; -fx-font-weight:bold;"/>
                    <TextField fx:id="keyTextField"
                               promptText="Base64 AES-256 key"
                               styleClass="form-field" HBox.hgrow="ALWAYS"/>
                    <Button text="Paste" onAction="#pasteKey"
                            prefWidth="70" styleClass="btn-ghost"/>
                </HBox>

                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="IV" styleClass="field-label" prefWidth="40"
                           style="-fx-text-fill:#8892aa; -fx-font-size:12px; -fx-font-weight:bold;"/>
                    <TextField fx:id="ivTextField"
                               promptText="Hex initialization vector"
                               styleClass="form-field" HBox.hgrow="ALWAYS"/>
                    <Button text="Paste" onAction="#pasteIv"
                            prefWidth="70" styleClass="btn-ghost"/>
                </HBox>
            </VBox>

            <!-- 3 — Output Folder -->
            <VBox styleClass="card" spacing="10">
                <Label text="OUTPUT FOLDER" styleClass="section-label"/>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <TextField fx:id="outputFolderTextField"
                               promptText="Where to save the .menc encrypted file"
                               styleClass="form-field" HBox.hgrow="ALWAYS"
                               editable="false"/>
                    <Button text="Browse Folder" onAction="#browseOutputFolder"
                            prefWidth="130" prefHeight="36" styleClass="btn-secondary"/>
                </HBox>
            </VBox>

            <!-- Action -->
            <Region VBox.vgrow="ALWAYS"/>
            <HBox alignment="CENTER_RIGHT">
                <Button text="&#128272;  Encrypt &amp; Save Patient Record"
                        onAction="#encryptFileAndHold"
                        prefHeight="42" styleClass="btn-success"/>
            </HBox>

        </VBox>
    </center>

</BorderPane>
