<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import java.net.URL?>
<?import javafx.geometry.Insets?>

<HBox xmlns:fx="http://javafx.com/fxml/1"
      xmlns="http://javafx.com/javafx/21"
      fx:controller="javafxapplication7.LoginController"
      prefWidth="760" prefHeight="500"
      styleClass="screen-root">

    <stylesheets><URL value="@styles.css"/></stylesheets>

    <!-- ── LEFT: Brand panel ── -->
    <VBox styleClass="login-brand-panel" spacing="0" alignment="TOP_LEFT">

        <!-- Hospital icon -->
        <Label text="&#127973;"
               style="-fx-font-size:42px; -fx-padding:0 0 20 0;"/>

        <Label text="Secure Medical&#10;Lab System"
               styleClass="login-brand-title"/>

        <Label text="Encrypted patient records,&#10;accessible only by authorized staff."
               styleClass="login-brand-sub"
               style="-fx-padding: 12 0 28 0;"/>

        <Label text="AES-256 Encrypted"
               styleClass="login-brand-tag"/>

        <Region VBox.vgrow="ALWAYS"/>

        <!-- Feature list -->
        <VBox spacing="8">
            <Label text="&#10003;  Per-file encryption keys"
                   styleClass="login-feature-label"/>
            <Label text="&#10003;  Role-based access control"
                   styleClass="login-feature-label"/>
            <Label text="&#10003;  Secure file deletion"
                   styleClass="login-feature-label"/>
            <Label text="&#10003;  Audit trail per record"
                   styleClass="login-feature-label"/>
        </VBox>

    </VBox>

    <!-- ── RIGHT: Login form ── -->
    <VBox styleClass="login-form-panel" HBox.hgrow="ALWAYS"
          alignment="CENTER" spacing="0">

        <VBox maxWidth="340" spacing="0">

            <Label text="Welcome back"
                   style="-fx-text-fill:#e8eaf0; -fx-font-size:22px; -fx-font-weight:bold;"/>
            <Label text="Sign in to access the portal"
                   style="-fx-text-fill:#3d4f65; -fx-font-size:13px; -fx-padding:6 0 28 0;"/>

            <!-- Username -->
            <Label text="USERNAME"
                   style="-fx-text-fill:#8892aa; -fx-font-size:11px; -fx-font-weight:bold;"/>
            <TextField fx:id="usernameField"
                       promptText="Enter your username"
                       styleClass="form-field"
                       maxWidth="Infinity">
                <VBox.margin><Insets top="6" bottom="16"/></VBox.margin>
            </TextField>

            <!-- Password -->
            <Label text="PASSWORD"
                   style="-fx-text-fill:#8892aa; -fx-font-size:11px; -fx-font-weight:bold;"/>
            <PasswordField fx:id="passwordField"
                           promptText="Enter your password"
                           styleClass="form-field"
                           maxWidth="Infinity">
                <VBox.margin><Insets top="6" bottom="8"/></VBox.margin>
            </PasswordField>

            <!-- Error label -->
            <Label fx:id="errorLabel" text=""
                   style="-fx-text-fill:#ef4444; -fx-font-size:12px; -fx-min-height:18;"/>

            <!-- Sign In button -->
            <Button text="Sign In"
                    onAction="#handleLogin"
                    maxWidth="Infinity"
                    prefHeight="42"
                    styleClass="btn-primary"
                    defaultButton="true">
                <VBox.margin><Insets top="16"/></VBox.margin>
            </Button>

            <!-- Hint -->
            <Label text="Default accounts: admin · technician · doctor"
                   style="-fx-text-fill:#1e2b3a; -fx-font-size:10px; -fx-padding: 16 0 0 0;"/>

        </VBox>
    </VBox>

</HBox>
