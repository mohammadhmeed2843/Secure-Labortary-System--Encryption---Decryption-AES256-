<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Text?>
<?import java.net.URL?>
<AnchorPane prefHeight="500.0" prefWidth="700.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="javafxapplication7.OpenDecryptionController"
            style="-fx-background-color:#2d2d2d">

    <!-- Header -->
    <Text layoutX="213" layoutY="70" text="Decryption Page"
          style="-fx-fill:white;-fx-font-size:28;-fx-font-family:'Helvetica Neue';-fx-font-weight:bold"/>

    <!-- Input Encrypted -->
    <Label text="Input .menc file(s):" layoutX="32" layoutY="120"
           style="-fx-text-fill:white;-fx-font-size:16;-fx-font-weight:bold"/>
    <TextField fx:id="inputFolderTextField" layoutX="170" layoutY="115" prefWidth="330"
               promptText="Select .menc file(s)" styleClass="dark-field"/>
    <Button text="Browse" layoutX="510" layoutY="115" prefWidth="140"
            onAction="#browseInputFolder" styleClass="main-btn"/>

    <!-- Key -->
    <Label text="Decryption Key:" layoutX="32" layoutY="180"
           style="-fx-text-fill:white;-fx-font-size:16;-fx-font-weight:bold"/>
    <TextField fx:id="keyTextField" layoutX="170" layoutY="175" prefWidth="270"
               promptText="Key" styleClass="dark-field"/>
    <Button text="Paste" layoutX="450" layoutY="175" prefWidth="60"
            onAction="#pasteKey" styleClass="small-btn"/>

    <!-- IV -->
    <Label text="Initialization Vector (IV):" layoutX="32" layoutY="240"
           style="-fx-text-fill:white;-fx-font-size:16;-fx-font-weight:bold"/>
    <TextField fx:id="ivTextField" layoutX="260" layoutY="235" prefWidth="180"
               promptText="IV" styleClass="dark-field"/>
    <Button text="Paste" layoutX="450" layoutY="235" prefWidth="60"
            onAction="#pasteIv" styleClass="small-btn"/>

    <!-- Output folder -->
    <Label text="Output Folder:" layoutX="32" layoutY="300"
           style="-fx-text-fill:white;-fx-font-size:16;-fx-font-weight:bold"/>
    <TextField fx:id="outputFolderTextField" layoutX="170" layoutY="295" prefWidth="270"
               promptText="Output folder" styleClass="dark-field"/>
    <Button text="Select Folder" layoutX="450" layoutY="295" prefWidth="140"
            onAction="#browseOutputFolder" styleClass="main-btn"/>

    <!-- Decrypt + Back -->
    <Button text="Decrypt" layoutX="280" layoutY="355" prefWidth="140" prefHeight="50"
            onAction="#decryptFolder" styleClass="main-btn"/>
    <Button text="Back" layoutX="15" layoutY="430" prefWidth="100"
            onAction="#backToHomePage" styleClass="main-btn"/>

    <stylesheets>
        <URL value="@styles.css"/>
    </stylesheets>
</AnchorPane>
