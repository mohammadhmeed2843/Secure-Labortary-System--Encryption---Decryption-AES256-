<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import java.net.URL?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      xmlns="http://javafx.com/javafx/21"
      fx:controller="javafxapplication7.ui.AdminRecoveryController"
      spacing="0"
      styleClass="content-area">

    <stylesheets><URL value="@/javafxapplication7/resources/css/styles.css"/></stylesheets>

    <!-- ── PAGE HEADER ── -->
    <VBox styleClass="page-header">
        <HBox alignment="CENTER_LEFT" spacing="14">
            <Label text="&#128260;"
                   style="-fx-font-size:14px; -fx-text-fill:#D97706;
                          -fx-background-color:#FFFBEB; -fx-background-radius:8; -fx-padding:6 8;"/>
            <VBox spacing="4">
                <Label text="File Recovery"
                       style="-fx-text-fill:#111827; -fx-font-size:22px; -fx-font-weight:bold;"/>
                <Label text="Restore archived patient records to active status"
                       style="-fx-text-fill:#6B7280; -fx-font-size:12px;"/>
            </VBox>
        </HBox>

        <HBox style="-fx-padding:16 0 0 0;">
            <Button text="&#8635;  Refresh List" onAction="#handleRefresh"
                    styleClass="btn-ghost" prefHeight="36"/>
        </HBox>
    </VBox>

    <!-- ── ARCHIVED FILES ── -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                style="-fx-background-color:transparent; -fx-border-width:0;">
        <content>
            <VBox fx:id="recoveryListBox" spacing="14"
                  style="-fx-padding:24 32 40 32; -fx-background-color:#F0F2F5;"/>
        </content>
    </ScrollPane>

</VBox>
