<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import java.net.URL?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      xmlns="http://javafx.com/javafx/21"
      fx:controller="javafxapplication7.HomePageController"
      spacing="0"
      styleClass="content-area">

    <stylesheets><URL value="@styles.css"/></stylesheets>

    <!-- Page header -->
    <VBox styleClass="page-header">
        <Label fx:id="lblWelcome"
               text="Dashboard"
               style="-fx-text-fill:#111827; -fx-font-size:22px; -fx-font-weight:bold;"/>
        <Label fx:id="lblRole"
               text="—"
               style="-fx-text-fill:#6B7280; -fx-font-size:12px; -fx-padding:4 0 0 0;"/>
    </VBox>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                style="-fx-background-color:transparent; -fx-border-width:0;">
        <content>
            <VBox spacing="20" style="-fx-padding:24 28 32 28; -fx-background-color:#F8F9FA;">

                <!-- Stat cards — built programmatically -->
                <HBox fx:id="statCardsRow" spacing="14"/>

                <!-- Quick actions -->
                <VBox styleClass="card" spacing="14">
                    <Label text="QUICK ACTIONS" styleClass="section-label"/>
                    <HBox fx:id="quickActionsBox" spacing="12"/>
                </VBox>

                <!-- System status -->
                <VBox styleClass="card" spacing="10">
                    <Label text="SYSTEM STATUS" styleClass="section-label"/>
                    <HBox spacing="12" alignment="CENTER_LEFT">
                        <Label text="&#9632;"
                               style="-fx-text-fill:#059669; -fx-font-size:10px;"/>
                        <Label text="All systems operational"
                               style="-fx-text-fill:#374151; -fx-font-size:12px; -fx-font-weight:bold;"/>
                    </HBox>
                    <HBox spacing="12" alignment="CENTER_LEFT">
                        <Label text="&#128274;"
                               style="-fx-font-size:12px;"/>
                        <Label text="AES-256 encryption active  ·  Role-based access enforced  ·  All actions logged"
                               style="-fx-text-fill:#6B7280; -fx-font-size:11px;" wrapText="true"/>
                    </HBox>
                </VBox>

            </VBox>
        </content>
    </ScrollPane>

</VBox>
