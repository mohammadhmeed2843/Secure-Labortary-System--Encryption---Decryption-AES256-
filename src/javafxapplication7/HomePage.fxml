<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import java.net.URL?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      xmlns="http://javafx.com/javafx/21"
      fx:controller="javafxapplication7.HomePageController"
      spacing="0"
      styleClass="content-area">

    <stylesheets><URL value="@styles.css"/></stylesheets>

    <!-- ── INNER HEADER ── -->
    <VBox style="-fx-padding: 28 28 20 28; -fx-background-color: #0f1117;">
        <Label fx:id="lblWelcome"
               text="Dashboard"
               style="-fx-text-fill:#e8eaf0; -fx-font-size:22px; -fx-font-weight:bold;"/>
        <Label fx:id="lblRole"
               text="—"
               style="-fx-text-fill:#3d4f65; -fx-font-size:12px; -fx-padding: 4 0 0 0;"/>
    </VBox>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                style="-fx-background-color:#0f1117; -fx-background:#0f1117; -fx-border-width:0;">
        <content>
            <VBox spacing="20" style="-fx-padding: 0 28 32 28;">

                <!-- Stat cards row — populated programmatically by controller -->
                <HBox fx:id="statCardsRow" spacing="12"/>

                <!-- Quick actions card -->
                <VBox styleClass="card" spacing="12">
                    <Label text="QUICK ACTIONS" styleClass="section-label"/>
                    <Label text="Navigate using the sidebar or the shortcuts below."
                           style="-fx-text-fill:#3d4f65; -fx-font-size:12px;"/>
                    <HBox fx:id="quickActionsBox" spacing="12"/>
                </VBox>

                <!-- System info card -->
                <VBox styleClass="card" spacing="8">
                    <Label text="SYSTEM" styleClass="section-label"/>
                    <Label text="AES-256 per-file encryption  ·  PBKDF2-HMAC-SHA256 authentication  ·  Role-based access control"
                           style="-fx-text-fill:#3d4f65; -fx-font-size:11px;" wrapText="true"/>
                    <Label text="All file encryption and decryption is transparent — no manual key handling required."
                           style="-fx-text-fill:#1e2b3a; -fx-font-size:11px;" wrapText="true"/>
                </VBox>

            </VBox>
        </content>
    </ScrollPane>

</VBox>
