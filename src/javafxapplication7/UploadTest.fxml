<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import java.net.URL?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      xmlns="http://javafx.com/javafx/21"
      fx:controller="javafxapplication7.UploadTestController"
      spacing="0"
      styleClass="content-area">

    <stylesheets><URL value="@styles.css"/></stylesheets>

    <!-- Page header -->
    <VBox styleClass="page-header">
        <Label text="New Test Record"
               style="-fx-text-fill:#111827; -fx-font-size:22px; -fx-font-weight:bold;"/>
        <Label text="Complete all sections below, then click Save Securely — the file is protected automatically"
               style="-fx-text-fill:#6B7280; -fx-font-size:12px; -fx-padding:4 0 0 0;"/>
        <!-- Step indicator -->
        <HBox spacing="6" alignment="CENTER_LEFT" style="-fx-padding:12 0 0 0;">
            <Label text="① Patient"
                   style="-fx-text-fill:#C41230; -fx-font-weight:bold; -fx-font-size:11px;"/>
            <Label text="›" style="-fx-text-fill:#D1D5DB; -fx-font-size:13px;"/>
            <Label text="② File" style="-fx-text-fill:#9CA3AF; -fx-font-size:11px;"/>
            <Label text="›" style="-fx-text-fill:#D1D5DB; -fx-font-size:13px;"/>
            <Label text="③ Test Details" style="-fx-text-fill:#9CA3AF; -fx-font-size:11px;"/>
            <Label text="›" style="-fx-text-fill:#D1D5DB; -fx-font-size:13px;"/>
            <Label text="④ Save" style="-fx-text-fill:#9CA3AF; -fx-font-size:11px;"/>
        </HBox>
    </VBox>

    <!-- Scrollable form -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                style="-fx-background-color:transparent; -fx-border-width:0;">
        <content>
            <VBox spacing="14" style="-fx-padding:20 28 32 28; -fx-background-color:#F8F9FA;">

                <!-- ① PATIENT INFORMATION -->
                <VBox styleClass="card" spacing="14">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label text="&#128100;" style="-fx-font-size:15px;"/>
                        <Label text="PATIENT INFORMATION" styleClass="section-label"
                               style="-fx-padding:0;"/>
                    </HBox>

                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                            <Label text="Patient ID Number" styleClass="field-label"/>
                            <TextField fx:id="patientNumberField"
                                       promptText="e.g. P-1001"
                                       styleClass="form-field"
                                       maxWidth="Infinity"/>
                        </VBox>
                        <Button text="Look Up Patient"
                                onAction="#handleLookupPatient"
                                prefWidth="130" prefHeight="38"
                                styleClass="btn-secondary"
                                style="-fx-translate-y:10;"/>
                    </HBox>

                    <GridPane hgap="14" vgap="12" maxWidth="Infinity">
                        <columnConstraints>
                            <ColumnConstraints hgrow="ALWAYS" fillWidth="true"/>
                            <ColumnConstraints hgrow="ALWAYS" fillWidth="true"/>
                        </columnConstraints>

                        <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="0">
                            <Label text="First Name" styleClass="field-label"/>
                            <TextField fx:id="firstNameField" promptText="Patient first name"
                                       styleClass="form-field" maxWidth="Infinity"/>
                        </VBox>
                        <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="0">
                            <Label text="Last Name" styleClass="field-label"/>
                            <TextField fx:id="lastNameField" promptText="Patient last name"
                                       styleClass="form-field" maxWidth="Infinity"/>
                        </VBox>
                        <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="1">
                            <Label text="Date of Birth" styleClass="field-label"/>
                            <DatePicker fx:id="dobPicker" maxWidth="Infinity"/>
                        </VBox>
                    </GridPane>
                </VBox>

                <!-- Version update (shown after patient lookup) -->
                <VBox fx:id="existingRecordsSection" styleClass="card" spacing="10"
                      visible="false" managed="false"
                      style="-fx-border-color:#FDE8EC; -fx-background-color:#FFFAFA;">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label text="&#8635;" style="-fx-font-size:14px; -fx-text-fill:#C41230;"/>
                        <Label text="UPDATE EXISTING RECORD" styleClass="section-label"
                               style="-fx-padding:0;"/>
                    </HBox>
                    <Label text="This patient already has records on file. Select one to create an updated version (the previous file will be archived), or leave blank to add a new independent record."
                           style="-fx-text-fill:#6B7280; -fx-font-size:11px;" wrapText="true"/>
                    <VBox spacing="4">
                        <Label text="Record to Update" styleClass="field-label"/>
                        <ComboBox fx:id="supersededRecordBox" maxWidth="Infinity"
                                  promptText="— Create new record —"/>
                    </VBox>
                </VBox>

                <!-- ② PDF FILE -->
                <VBox styleClass="card" spacing="12">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label text="&#128196;" style="-fx-font-size:15px;"/>
                        <Label text="TEST REPORT FILE" styleClass="section-label"
                               style="-fx-padding:0;"/>
                    </HBox>
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <TextField fx:id="filePathField"
                                   promptText="No file selected — click Browse to choose a PDF"
                                   styleClass="form-field" HBox.hgrow="ALWAYS"
                                   editable="false"/>
                        <Button text="Browse…"
                                onAction="#handleBrowseFile"
                                prefWidth="100" prefHeight="38"
                                styleClass="btn-primary"/>
                    </HBox>
                    <HBox spacing="6" alignment="CENTER_LEFT">
                        <Label text="&#128274;" style="-fx-font-size:11px; -fx-text-fill:#C41230;"/>
                        <Label text="The original file is securely erased after saving. Files are protected with AES-256 encryption."
                               style="-fx-text-fill:#9CA3AF; -fx-font-size:11px;" wrapText="true"/>
                    </HBox>
                </VBox>

                <!-- ③ TEST DETAILS -->
                <VBox styleClass="card" spacing="14">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label text="&#128203;" style="-fx-font-size:15px;"/>
                        <Label text="TEST DETAILS" styleClass="section-label"
                               style="-fx-padding:0;"/>
                    </HBox>
                    <GridPane hgap="14" vgap="12" maxWidth="Infinity">
                        <columnConstraints>
                            <ColumnConstraints hgrow="ALWAYS" fillWidth="true"/>
                            <ColumnConstraints hgrow="ALWAYS" fillWidth="true"/>
                        </columnConstraints>

                        <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="0">
                            <Label text="Test Type" styleClass="field-label"/>
                            <ComboBox fx:id="testTypeBox" maxWidth="Infinity"
                                      promptText="Select test type"/>
                        </VBox>
                        <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="0">
                            <Label text="Test Status" styleClass="field-label"/>
                            <ComboBox fx:id="statusBox" maxWidth="Infinity"
                                      promptText="Select status"/>
                        </VBox>
                        <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="1">
                            <Label text="Assigned Doctor" styleClass="field-label"/>
                            <ComboBox fx:id="doctorBox" maxWidth="Infinity"
                                      promptText="Select doctor"/>
                        </VBox>
                        <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="1">
                            <Label text="Lab Technician" styleClass="field-label"/>
                            <ComboBox fx:id="technicianBox" maxWidth="Infinity"
                                      promptText="Select technician"/>
                        </VBox>
                        <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="2">
                            <Label text="Test Date" styleClass="field-label"/>
                            <DatePicker fx:id="testDatePicker" maxWidth="Infinity"/>
                        </VBox>
                    </GridPane>
                </VBox>

                <!-- ④ STATUS + ACTIONS -->
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <ProgressIndicator fx:id="progressIndicator"
                                       prefWidth="22" prefHeight="22"
                                       style="-fx-progress-color:#C41230;"
                                       visible="false"/>
                    <Label fx:id="statusLabel" text=""
                           style="-fx-font-size:12px;"
                           HBox.hgrow="ALWAYS" wrapText="true"/>
                </HBox>

                <HBox alignment="CENTER_RIGHT" spacing="10">
                    <Button text="Reset Form"
                            onAction="#handleReset"
                            prefHeight="38" styleClass="btn-ghost"/>
                    <Button fx:id="saveButton"
                            text="&#128274;  Save Securely"
                            onAction="#handleSave"
                            prefHeight="42" prefWidth="180"
                            styleClass="btn-success"/>
                </HBox>

            </VBox>
        </content>
    </ScrollPane>

</VBox>
