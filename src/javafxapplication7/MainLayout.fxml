<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import java.net.URL?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/21"
            fx:controller="javafxapplication7.MainLayoutController"
            prefWidth="980" prefHeight="640"
            styleClass="screen-root">

    <stylesheets><URL value="@styles.css"/></stylesheets>

    <!-- ══════════════════════════════════════
         SIDEBAR
         ══════════════════════════════════════ -->
    <left>
        <VBox styleClass="sidebar">

            <!-- Brand -->
            <VBox styleClass="sidebar-brand" spacing="4">
                <Label text="&#127973;" style="-fx-font-size:24px;"/>
                <Label text="Medical Files"
                       style="-fx-text-fill:#c8d0e0; -fx-font-size:15px; -fx-font-weight:bold;"/>
                <Label text="Secure File System"
                       style="-fx-text-fill:#1e2b3a; -fx-font-size:10px;"/>
            </VBox>

            <!-- Nav section -->
            <Label text="WORKSPACE" styleClass="nav-section-label"/>

            <Button fx:id="navDashboard"
                    text="  &#8801;   Dashboard"
                    onAction="#showDashboard"
                    styleClass="nav-item"
                    maxWidth="Infinity"/>

            <Button fx:id="navEncrypt"
                    text="  &#8593;   Encrypt Files"
                    onAction="#showEncrypt"
                    styleClass="nav-item"
                    maxWidth="Infinity"/>

            <Button fx:id="navDecrypt"
                    text="  &#8595;   Decrypt Files"
                    onAction="#showDecrypt"
                    styleClass="nav-item"
                    maxWidth="Infinity"/>

            <!-- Push footer to bottom -->
            <Region VBox.vgrow="ALWAYS"/>

            <!-- Footer info -->
            <Label text="SYSTEM" styleClass="nav-section-label"/>
            <Label text="AES-256 · CBC Mode"     styleClass="sidebar-footer-label"/>
            <Label text="PostgreSQL · localhost"  styleClass="sidebar-footer-label">
                <VBox.margin><Insets bottom="16"/></VBox.margin>
            </Label>

        </VBox>
    </left>

    <!-- ══════════════════════════════════════
         CONTENT AREA (swapped on navigation)
         ══════════════════════════════════════ -->
    <center>
        <StackPane fx:id="contentArea" styleClass="content-area" alignment="TOP_LEFT"/>
    </center>

</BorderPane>
