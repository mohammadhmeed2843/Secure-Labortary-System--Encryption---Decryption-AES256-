<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import java.net.URL?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/21"
            fx:controller="javafxapplication7.MainLayoutController"
            prefWidth="1080" prefHeight="700"
            styleClass="screen-root">

    <stylesheets><URL value="@styles.css"/></stylesheets>

    <left>
        <VBox styleClass="sidebar">

            <!-- Brand -->
            <VBox styleClass="sidebar-brand" spacing="3">
                <Label text="&#9764;"
                       style="-fx-font-size:22px; -fx-text-fill:#C41230;"/>
                <Label text="MedLab Secure"
                       style="-fx-text-fill:#111827; -fx-font-size:15px; -fx-font-weight:bold;"/>
                <Label text="Laboratory File System"
                       style="-fx-text-fill:#9CA3AF; -fx-font-size:10px;"/>
            </VBox>

            <Label text="WORKSPACE" styleClass="nav-section-label"/>

            <Button fx:id="navDashboard"
                    text="  &#8801;   Dashboard"
                    onAction="#showDashboard"
                    styleClass="nav-item"
                    maxWidth="Infinity"/>

            <Button fx:id="navUpload"
                    text="  &#8679;   New Test Record"
                    onAction="#showUpload"
                    styleClass="nav-item"
                    maxWidth="Infinity"/>

            <Button fx:id="navRecords"
                    text="  &#9776;   All Records"
                    onAction="#showRecords"
                    styleClass="nav-item"
                    maxWidth="Infinity"/>

            <Button fx:id="navPatientFiles"
                    text="  &#128196;   Patient Files"
                    onAction="#showPatientFiles"
                    styleClass="nav-item"
                    maxWidth="Infinity"/>

            <Label fx:id="navAdminSection" text="ADMINISTRATION"
                   styleClass="nav-section-label" managed="false" visible="false"/>

            <Button fx:id="navAdminUsers"
                    text="  &#128100;   User Accounts"
                    onAction="#showAdminUsers"
                    styleClass="nav-item"
                    maxWidth="Infinity"
                    managed="false" visible="false"/>

            <Button fx:id="navAdminAudit"
                    text="  &#128203;   Activity Log"
                    onAction="#showAdminAudit"
                    styleClass="nav-item"
                    maxWidth="Infinity"
                    managed="false" visible="false"/>

            <Button fx:id="navAdminRecovery"
                    text="  &#128260;   File Recovery"
                    onAction="#showAdminRecovery"
                    styleClass="nav-item"
                    maxWidth="Infinity"
                    managed="false" visible="false"/>

            <Region VBox.vgrow="ALWAYS"/>

            <!-- Signed-in user footer -->
            <VBox style="-fx-padding:12 16 16 16;
                         -fx-background-color:#FAFAFA;
                         -fx-border-color:#E5E7EB transparent transparent transparent;
                         -fx-border-width:1 0 0 0;">
                <Label text="SIGNED IN AS" styleClass="nav-section-label"
                       style="-fx-padding:0 0 4 0;"/>
                <Label fx:id="lblUserName" text="—"
                       style="-fx-text-fill:#374151; -fx-font-size:12px; -fx-font-weight:bold;"/>
                <Label fx:id="lblUserRole" text="—"
                       style="-fx-text-fill:#9CA3AF; -fx-font-size:10px;"/>
            </VBox>

        </VBox>
    </left>

    <center>
        <StackPane fx:id="contentArea" styleClass="content-area" alignment="TOP_LEFT"/>
    </center>

</BorderPane>
