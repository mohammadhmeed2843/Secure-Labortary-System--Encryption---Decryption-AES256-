<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import java.net.URL?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      xmlns="http://javafx.com/javafx/21"
      fx:controller="javafxapplication7.openEncryptionController"
      spacing="0"
      styleClass="content-area">

    <stylesheets><URL value="@styles.css"/></stylesheets>

    <VBox style="-fx-padding: 28 28 20 28; -fx-background-color: #0f1117;">
        <Label text="Upload Medical File"
               style="-fx-text-fill:#e8eaf0; -fx-font-size:22px; -fx-font-weight:bold;"/>
        <Label text="Select a PDF — encryption happens automatically when you save the record"
               style="-fx-text-fill:#3d4f65; -fx-font-size:12px; -fx-padding: 4 0 0 0;"/>
        <HBox spacing="8" alignment="CENTER_LEFT" style="-fx-padding: 12 0 0 0;">
            <Label text="① Select File"
                   style="-fx-text-fill:#3b82f6; -fx-font-weight:bold; -fx-font-size:11px;"/>
            <Label text="›" style="-fx-text-fill:#1e2b3a; -fx-font-size:13px;"/>
            <Label text="② Fill Patient Info"  style="-fx-text-fill:#3d4f65; -fx-font-size:11px;"/>
            <Label text="›" style="-fx-text-fill:#1e2b3a; -fx-font-size:13px;"/>
            <Label text="③ Save Record"        style="-fx-text-fill:#3d4f65; -fx-font-size:11px;"/>
        </HBox>
    </VBox>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                style="-fx-background-color: #0f1117; -fx-background: #0f1117; -fx-border-width:0;">
        <content>
            <VBox spacing="14" style="-fx-padding: 0 28 24 28;">

                <VBox styleClass="card" spacing="10">
                    <Label text="PDF FILE" styleClass="section-label"/>
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <TextField fx:id="inputFolderTextField"
                                   promptText="No file selected — click Browse"
                                   styleClass="form-field" HBox.hgrow="ALWAYS"
                                   editable="false"/>
                        <Button text="Browse Files" onAction="#browseInputFolder"
                                prefWidth="130" prefHeight="36" styleClass="btn-primary"/>
                    </HBox>
                </VBox>

                <VBox styleClass="card" spacing="8">
                    <Label text="SECURITY"
                           style="-fx-text-fill:#10b981; -fx-font-size:10px; -fx-font-weight:bold;"/>
                    <Label text="Encryption is fully automatic."
                           style="-fx-text-fill:#e8eaf0; -fx-font-size:13px; -fx-font-weight:bold;"/>
                    <Label text="A unique AES-256 key and IV are generated per file and stored securely. The original file is securely removed after a confirmed save. No manual key handling required."
                           style="-fx-text-fill:#3d4f65; -fx-font-size:12px;" wrapText="true"/>
                </VBox>

                <HBox alignment="CENTER_RIGHT" style="-fx-padding: 8 0 0 0;">
                    <Button text="Next: Fill Patient Details  ›"
                            onAction="#proceed"
                            prefHeight="42" styleClass="btn-success"/>
                </HBox>

            </VBox>
        </content>
    </ScrollPane>

</VBox>
