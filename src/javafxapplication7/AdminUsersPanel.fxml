<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import java.net.URL?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      xmlns="http://javafx.com/javafx/21"
      fx:controller="javafxapplication7.AdminUsersController"
      spacing="0"
      styleClass="content-area">

    <stylesheets><URL value="@styles.css"/></stylesheets>

    <VBox styleClass="page-header">
        <Label text="User Accounts"
               style="-fx-text-fill:#111827; -fx-font-size:22px; -fx-font-weight:bold;"/>
        <Label text="Create accounts, reset passwords, and control access"
               style="-fx-text-fill:#6B7280; -fx-font-size:12px; -fx-padding:4 0 0 0;"/>
    </VBox>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                style="-fx-background-color:transparent; -fx-border-width:0;">
        <content>
            <VBox spacing="16" style="-fx-padding:20 28 32 28; -fx-background-color:#F8F9FA;">

                <!-- Create user -->
                <VBox styleClass="card" spacing="14">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label text="&#43;" style="-fx-font-size:16px; -fx-text-fill:#C41230;"/>
                        <Label text="CREATE NEW ACCOUNT" styleClass="section-label"
                               style="-fx-padding:0;"/>
                    </HBox>
                    <GridPane hgap="14" vgap="10" maxWidth="Infinity">
                        <columnConstraints>
                            <ColumnConstraints hgrow="ALWAYS" fillWidth="true"/>
                            <ColumnConstraints hgrow="ALWAYS" fillWidth="true"/>
                        </columnConstraints>
                        <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="0">
                            <Label text="Username" styleClass="field-label"/>
                            <TextField fx:id="newUsernameField" promptText="username"
                                       styleClass="form-field" maxWidth="Infinity"/>
                        </VBox>
                        <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="0">
                            <Label text="Full Name" styleClass="field-label"/>
                            <TextField fx:id="newFullNameField" promptText="Display name"
                                       styleClass="form-field" maxWidth="Infinity"/>
                        </VBox>
                        <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="1">
                            <Label text="Password" styleClass="field-label"/>
                            <PasswordField fx:id="newPasswordField" promptText="Min. 8 characters"
                                           styleClass="form-field" maxWidth="Infinity"/>
                        </VBox>
                        <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="1">
                            <Label text="Role" styleClass="field-label"/>
                            <ComboBox fx:id="newRoleBox" maxWidth="Infinity"
                                      promptText="Select role"/>
                        </VBox>
                    </GridPane>
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label fx:id="createStatusLabel" text=""
                               style="-fx-font-size:12px;" HBox.hgrow="ALWAYS" wrapText="true"/>
                        <Button text="Create Account" onAction="#handleCreateUser"
                                styleClass="btn-primary" prefHeight="38"/>
                    </HBox>
                </VBox>

                <!-- User list -->
                <VBox styleClass="card" spacing="12">
                    <HBox alignment="CENTER_LEFT">
                        <Label text="ALL ACCOUNTS" styleClass="section-label"
                               HBox.hgrow="ALWAYS"/>
                        <Button text="&#8635; Refresh" onAction="#handleRefresh"
                                styleClass="btn-ghost" prefHeight="30"/>
                    </HBox>
                    <VBox fx:id="userListBox" spacing="8"/>
                </VBox>

                <!-- Reset password (shown on demand) -->
                <VBox fx:id="resetSection" styleClass="card" spacing="12"
                      visible="false" managed="false"
                      style="-fx-border-color:#FDE8EC;">
                    <Label text="RESET PASSWORD" styleClass="section-label"/>
                    <Label fx:id="resetTargetLabel" text=""
                           style="-fx-text-fill:#374151; -fx-font-size:12px;"/>
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <PasswordField fx:id="resetPasswordField" promptText="New password (min. 8 chars)"
                                       styleClass="form-field" HBox.hgrow="ALWAYS"/>
                        <Button text="Apply" onAction="#handleResetPassword"
                                styleClass="btn-primary" prefHeight="36"/>
                        <Button text="Cancel" onAction="#handleCancelReset"
                                styleClass="btn-ghost" prefHeight="36"/>
                    </HBox>
                    <Label fx:id="resetStatusLabel" text=""
                           style="-fx-font-size:12px;" wrapText="true"/>
                </VBox>

            </VBox>
        </content>
    </ScrollPane>

</VBox>
