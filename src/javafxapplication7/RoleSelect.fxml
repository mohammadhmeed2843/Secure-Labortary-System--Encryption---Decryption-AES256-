<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import java.net.URL?>
<?import javafx.geometry.Insets?>

<StackPane xmlns:fx="http://javafx.com/fxml/1"
           xmlns="http://javafx.com/javafx/21"
           fx:controller="javafxapplication7.RoleSelectController"
           style="-fx-background-color:#F8F9FA;"
           prefWidth="880" prefHeight="560">

    <stylesheets><URL value="@styles.css"/></stylesheets>

    <VBox alignment="CENTER" spacing="0">

        <!-- ── BRAND HEADER ── -->
        <VBox alignment="CENTER" spacing="6"
              style="-fx-padding:48 0 40 0;">
            <Label text="&#127973;"
                   style="-fx-font-size:40px;"/>
            <Label text="Secure Medical Lab System"
                   style="-fx-text-fill:#111827; -fx-font-size:26px; -fx-font-weight:bold;"/>
            <Label text="Select your role to continue"
                   style="-fx-text-fill:#6B7280; -fx-font-size:13px;"/>
        </VBox>

        <!-- ── ROLE CARDS ROW ── -->
        <HBox fx:id="roleCardsRow" alignment="CENTER" spacing="24"
              style="-fx-padding:0 60;">

            <!-- Receptionist -->
            <VBox fx:id="cardReceptionist" styleClass="role-card" alignment="CENTER"
                  spacing="12" onMouseClicked="#handleRoleSelected"
                  style="-fx-pref-width:200; -fx-pref-height:190;">
                <Label text="&#128203;"
                       style="-fx-font-size:38px;"/>
                <Label text="Receptionist"
                       style="-fx-text-fill:#111827; -fx-font-size:16px; -fx-font-weight:bold;"/>
                <Label text="Upload &amp; manage\npatient records"
                       style="-fx-text-fill:#6B7280; -fx-font-size:11px;"
                       textAlignment="CENTER" wrapText="true"/>
            </VBox>

            <!-- Doctor -->
            <VBox fx:id="cardDoctor" styleClass="role-card" alignment="CENTER"
                  spacing="12" onMouseClicked="#handleRoleSelected"
                  style="-fx-pref-width:200; -fx-pref-height:190;">
                <Label text="&#128657;"
                       style="-fx-font-size:38px;"/>
                <Label text="Doctor"
                       style="-fx-text-fill:#111827; -fx-font-size:16px; -fx-font-weight:bold;"/>
                <Label text="View patient\ntest results"
                       style="-fx-text-fill:#6B7280; -fx-font-size:11px;"
                       textAlignment="CENTER" wrapText="true"/>
            </VBox>

            <!-- Admin -->
            <VBox fx:id="cardAdmin" styleClass="role-card" alignment="CENTER"
                  spacing="12" onMouseClicked="#handleRoleSelected"
                  style="-fx-pref-width:160; -fx-pref-height:160; -fx-opacity:0.75;">
                <Label text="&#9881;"
                       style="-fx-font-size:30px;"/>
                <Label text="Admin"
                       style="-fx-text-fill:#374151; -fx-font-size:14px; -fx-font-weight:bold;"/>
                <Label text="System management"
                       style="-fx-text-fill:#9CA3AF; -fx-font-size:10px;"
                       textAlignment="CENTER" wrapText="true"/>
            </VBox>

        </HBox>

        <!-- ── PASSWORD PANEL (hidden until role clicked) ── -->
        <VBox fx:id="passwordPanel" alignment="CENTER" spacing="14"
              visible="false" managed="false"
              style="-fx-padding:32 0 0 0; -fx-min-width:380; -fx-max-width:380;">

            <Label fx:id="selectedRoleLabel"
                   text=""
                   style="-fx-text-fill:#C41230; -fx-font-size:13px; -fx-font-weight:bold;"/>

            <PasswordField fx:id="passwordField"
                           promptText="Enter your password"
                           styleClass="form-field"
                           maxWidth="380"
                           onAction="#handleSignIn"/>

            <Label fx:id="errorLabel" text=""
                   style="-fx-text-fill:#DC2626; -fx-font-size:12px;"
                   wrapText="true" maxWidth="380"/>

            <HBox spacing="10" alignment="CENTER">
                <Button text="Cancel"
                        onAction="#handleCancel"
                        styleClass="btn-ghost"
                        prefWidth="100" prefHeight="38"/>
                <Button fx:id="signInButton"
                        text="Sign In"
                        onAction="#handleSignIn"
                        styleClass="btn-primary"
                        prefWidth="160" prefHeight="38"/>
            </HBox>

            <ProgressIndicator fx:id="loadingIndicator"
                               prefWidth="28" prefHeight="28"
                               visible="false"
                               style="-fx-progress-color:#C41230;"/>
        </VBox>

        <!-- ── FOOTER ── -->
        <Label text="All data is encrypted with AES-256. Access is logged."
               style="-fx-text-fill:#D1D5DB; -fx-font-size:10px; -fx-padding:36 0 0 0;"/>

    </VBox>

</StackPane>
