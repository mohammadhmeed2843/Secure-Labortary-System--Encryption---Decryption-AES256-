<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import java.net.URL?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      xmlns="http://javafx.com/javafx/21"
      fx:controller="javafxapplication7.PatientFilesController"
      spacing="0"
      styleClass="content-area">

    <stylesheets><URL value="@styles.css"/></stylesheets>

    <!-- Page header -->
    <VBox styleClass="page-header">
        <Label text="Patient Files"
               style="-fx-text-fill:#111827; -fx-font-size:22px; -fx-font-weight:bold;"/>
        <Label text="Search for a patient, then open their test results"
               style="-fx-text-fill:#6B7280; -fx-font-size:12px; -fx-padding:4 0 0 0;"/>
    </VBox>

    <!-- Split layout -->
    <HBox VBox.vgrow="ALWAYS" spacing="0">

        <!-- LEFT: patient list -->
        <VBox styleClass="patient-list-panel" spacing="0">

            <VBox style="-fx-padding:14 12 10 12;" spacing="8">
                <TextField fx:id="searchPatientField"
                           promptText="&#128269; Search patients…"
                           styleClass="search-field"/>
                <Button text="&#8635;  Refresh"
                        onAction="#handleRefreshPatients"
                        styleClass="btn-ghost"
                        maxWidth="Infinity"/>
            </VBox>

            <Separator/>

            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                        hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                        style="-fx-background-color:transparent; -fx-border-width:0;">
                <content>
                    <VBox fx:id="patientListContainer" spacing="0"
                          style="-fx-background-color:#F8F9FA;"/>
                </content>
            </ScrollPane>
        </VBox>

        <!-- RIGHT: file cards -->
        <VBox VBox.vgrow="ALWAYS" HBox.hgrow="ALWAYS" spacing="0"
              style="-fx-background-color:#F8F9FA;">

            <!-- Right panel header -->
            <HBox style="-fx-padding:16 24; -fx-background-color:#FFFFFF;
                         -fx-border-color:transparent transparent #E5E7EB transparent;
                         -fx-border-width:0 0 1 0;"
                  alignment="CENTER_LEFT" spacing="12">
                <VBox HBox.hgrow="ALWAYS">
                    <Label fx:id="selectedPatientLabel"
                           text="Select a patient"
                           style="-fx-text-fill:#111827; -fx-font-size:15px; -fx-font-weight:bold;"/>
                    <Label fx:id="filesHeaderLabel"
                           text="No patient selected"
                           style="-fx-text-fill:#9CA3AF; -fx-font-size:11px;"/>
                </VBox>
            </HBox>

            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                        hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                        style="-fx-background-color:transparent; -fx-border-width:0;">
                <content>
                    <VBox fx:id="filesContainer" spacing="12"
                          style="-fx-padding:20 24; -fx-background-color:#F8F9FA;"/>
                </content>
            </ScrollPane>
        </VBox>

    </HBox>

</VBox>
