<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Text?>

<AnchorPane xmlns:fx="http://javafx.com/fxml" fx:controller="javafxapplication7.LoginController"
            prefWidth="400" prefHeight="300" style="-fx-background-color: #2d2d2d;">

    <Text layoutX="120" layoutY="60" text="Secure Login"
          style="-fx-fill: white; -fx-font-size: 22px; -fx-font-family: 'Helvetica Neue';"/>

    <Label layoutX="50" layoutY="100" text="Username:" style="-fx-text-fill: white;"/>
    <TextField fx:id="usernameField" layoutX="130" layoutY="95" prefWidth="200"/>

    <Label layoutX="50" layoutY="150" text="Password:" style="-fx-text-fill: white;"/>
    <PasswordField fx:id="passwordField" layoutX="130" layoutY="145" prefWidth="200"/>

    <Button text="Login" layoutX="150" layoutY="210" prefWidth="100" onAction="#handleLogin"
            style="-fx-background-color: #3e3e3e; -fx-text-fill: white;"/>
</AnchorPane>
