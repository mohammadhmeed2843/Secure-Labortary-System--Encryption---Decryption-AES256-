<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import java.net.URL?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      xmlns="http://javafx.com/javafx/21"
      fx:controller="javafxapplication7.AdminRecoveryController"
      spacing="0"
      styleClass="content-area">

    <stylesheets><URL value="@styles.css"/></stylesheets>

    <VBox styleClass="page-header">
        <Label text="File Recovery"
               style="-fx-text-fill:#111827; -fx-font-size:22px; -fx-font-weight:bold;"/>
        <Label text="Restore previous versions of archived patient records"
               style="-fx-text-fill:#6B7280; -fx-font-size:12px; -fx-padding:4 0 0 0;"/>
        <HBox style="-fx-padding:12 0 0 0;">
            <Button text="&#8635; Refresh" onAction="#handleRefresh"
                    styleClass="btn-secondary" prefHeight="34"/>
        </HBox>
    </VBox>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                style="-fx-background-color:transparent; -fx-border-width:0;">
        <content>
            <VBox fx:id="recoveryListBox" spacing="10"
                  style="-fx-padding:16 28 28 28; -fx-background-color:#F8F9FA;"/>
        </content>
    </ScrollPane>

</VBox>
